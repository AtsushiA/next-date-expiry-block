{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "next/block-next-date-expiry-block",
  "version": "1.0.0",
  "title": "Date Expiry Text Block",
  "category": "text",
  "icon": "calendar-alt",
  "description": "Displays custom text when a specified custom field date has passed.",
  "example": {
    "attributes": {
      "customFieldName": "expiry_date",
      "dateFormat": "Y-m-d",
      "content": "This content has expired."
    }
  },
  "attributes": {
    "customFieldName": {
      "type": "string",
      "default": ""
    },
    "dateFormat": {
      "type": "string",
      "default": "Y-m-d"
    },
    "content": {
      "type": "string",
      "default": ""
    },
    "textAlign": {
      "type": "string"
    }
  },
  "supports": {
    "html": false,
    "color": {
      "gradients": true,
      "text": true,
      "background": true
    },
    "typography": {
      "fontSize": true,
      "lineHeight": true,
      "__experimentalFontFamily": true,
      "__experimentalFontWeight": true,
      "__experimentalFontStyle": true,
      "__experimentalTextTransform": true,
      "__experimentalTextDecoration": true,
      "__experimentalLetterSpacing": true
    },
    "spacing": {
      "margin": true,
      "padding": true
    },
    "__experimentalBorder": {
      "radius": true,
      "width": true,
      "color": true,
      "style": true
    }
  },
  "textdomain": "next-date-expiry-block",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}