#. Plugin Name of the plugin
#: telex-date-expiry-block.php
msgid "NExT Date Expiry Text Block"
msgstr "NExT 期限切れテキストブロック"

#. Description of the plugin
#: telex-date-expiry-block.php
msgid "A block that displays custom text when a specified custom field date has passed. Supports full paragraph-level text styling."
msgstr "指定したカスタムフィールドの日付を過ぎると任意のテキストを表示するブロックです。段落ブロックと同等のテキスト装飾に対応しています。"

#. Author of the plugin
#: telex-date-expiry-block.php
msgid "NExT-Season with WordPress Telex"
msgstr "NExT-Season with WordPress Telex"

#. Author URI of the plugin
#: telex-date-expiry-block.php
msgid "https://next-season.net/"
msgstr "https://next-season.net/"

#: build/index.js:1
#: src/edit.js:66
msgid "Expiry Settings"
msgstr "期限設定"

#: build/index.js:1
#: src/edit.js:72
msgid "Custom Field Name"
msgstr "カスタムフィールド名"

#: build/index.js:1
#: src/edit.js:76
msgid "Enter the meta key name that stores the expiry date."
msgstr "有効期限の日付が保存されているメタキー名を入力してください。"

#: build/index.js:1
#: src/edit.js:86
msgid "Date Format"
msgstr "日付フォーマット"

#: build/index.js:1
#: src/edit.js:90
msgid "PHP date format of the custom field value. Default: Y-m-d"
msgstr "カスタムフィールドに保存されている PHP 日付フォーマット。デフォルト: Y-m-d"

#: build/index.js:1
#: src/edit.js:105
msgid "Please set a custom field name in the block settings."
msgstr "ブロック設定でカスタムフィールド名を設定してください。"

#: build/index.js:1
#: src/edit.js:118
msgid "Enter text to display when the date has expired…"
msgstr "期限切れ後に表示するテキストを入力…"

